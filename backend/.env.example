# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/shadow_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Database SSL/TLS (production — leave blank for local dev)
# Values: disable, allow, prefer, require, verify-ca, verify-full
DB_SSL_MODE=
# Path to CA certificate file (required for verify-ca / verify-full)
DB_SSL_CERT_PATH=

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development

# CORS (for frontend)
FRONTEND_URL=http://localhost:3000
PRODUCTION_FRONTEND_URL=https://shadow.pau.edu.ng

# SmartStudy v2.0 - OpenAI API
OPENAI_API_KEY=your-openai-api-key-here

# Serper.dev Google Search API (2,500 free queries) - for real article links
SERPER_API_KEY=your-serper-api-key-here

# ElevenLabs TTS - for in-app audio summaries
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# SMTP Configuration (email service — optional, logs emails if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@shadow.pau.edu.ng

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ClamAV Virus Scanning (optional)
CLAMAV_HOST=

# Logging
LOG_LEVEL=INFO

# Sentry Error Tracking (optional - leave blank to disable)
SENTRY_DSN=

# Admin Configuration (comma-separated list of admin emails)
ADMIN_EMAILS=

# AI Daily Usage Limits (per user)
AI_DAILY_LIMIT_CHAT=100
AI_DAILY_LIMIT_PLANS=20
AI_DAILY_LIMIT_QUIZZES=30
AI_DAILY_LIMIT_AUDIO=50
AI_DAILY_LIMIT_EXERCISES=30
AI_DAILY_LIMIT_DIAGRAMS=20
