# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/shadow_db

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment
ENVIRONMENT=development

# CORS (for frontend)
FRONTEND_URL=http://localhost:3000

# SmartStudy v2.0 - OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Serper.dev Google Search API (2,500 free queries) - for real article links
SERPER_API_KEY=your-serper-api-key-here

# ElevenLabs TTS - for in-app audio summaries
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Logging
LOG_LEVEL=INFO
